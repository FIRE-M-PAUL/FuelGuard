SECRET_KEY=change-this-secret-key
JWT_SECRET=change-this-jwt-secret
# Used when seeding the first admin, and when syncing (see below).
ADMIN_INITIAL_PASSWORD=admin#G06
# Set to 1 once if login fails after changing the default password (old DB hash). Then remove it.
ADMIN_SYNC_PASSWORD_AT_STARTUP=0
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=1
OPEN_BROWSER=1
SESSION_COOKIE_SECURE=0
# Minutes of no activity before redirect to login (default 10). Cookie Max-Age defaults to 15 so it is not shorter than idle.
# SESSION_IDLE_MINUTES=10
# SESSION_COOKIE_MAX_AGE_MINUTES=15
